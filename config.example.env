# trace-saver plugin — optional config.
# Copy the lines you want into ~/.hermes/.env (or your shell rc) and edit.

# Your display name on the leaderboard (default: system user).
TRACE_LEADERBOARD_NAME=your-name

# Leaderboard base URL (default shown).
TRACE_LEADERBOARD_URL=http://10.9.66.12:8848

# Where `--local` writes zips (default: ~/hermes-traces).
# TRACE_SAVE_DIR=/path/to/traces

# Hermes home, if non-standard (default: ~/.hermes). Traces live in <home>/sessions/.
# HERMES_HOME=/home/you/.hermes
